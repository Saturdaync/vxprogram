/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.userinfo {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #aaa;
  width: 80%;
}

.userinfo-avatar {
  overflow: hidden;
  width: 128rpx;
  height: 128rpx;
  margin: 20rpx;
  border-radius: 50%;
}

.usermotto {
  margin-top: 200px;
}

.avatar-wrapper {
  padding: 0;
  width: 56px !important;
  border-radius: 8px;
  margin-top: 40px;
  margin-bottom: 40px;
}

.avatar {
  display: block;
  width: 56px;
  height: 56px;
}

.nickname-wrapper {
  display: flex;
  width: 100%;
  padding: 16px;
  box-sizing: border-box;
  border-top: .5px solid rgba(0, 0, 0, 0.1);
  border-bottom: .5px solid rgba(0, 0, 0, 0.1);
  color: black;
}

.nickname-label {
  width: 105px;
}

.nickname-input {
  flex: 1;
}

/*index页面的css */
/*搜索框*/
.part-1-search{
    width: 100%;
    height: 100rpx;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 10rpx;
}
.search-content{
  display: flex;
  align-items: center;
  padding-left:20rpx ;
  width: 60%;
  height: 100%;
  background-color: white;
  border-radius: 20rpx;
  margin-right: 20rpx;
  box-sizing: border-box;
}
.search-content>image{
  height: 65%;
  width: 60rpx;
  margin-left: auto;
  margin-right: 20rpx;
}
.part-1-text{
  font-weight: bold;
  font-size: 40rpx;
  color: #4169E1 ;
}
/*part-2的商品种类选择*/
.part-2-select{
  width: 90%;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 10px;
  padding-right:10px;
}
.part-2-item{
  margin: 10px;
  font-size: 30rpx;
}
/*part-3的商品*/
.part-3-item{
  width: 100%;
  display: flex;
  flex-wrap: wrap;
}
.item{
  width: 50%;
  min-height: 450rpx;
  display: flex;
  flex-direction: column;
  padding: 10rpx;
  box-sizing: border-box;
  border-radius: 5%;
  box-shadow: 0 8rpx 12rpx rgba(0, 0, 0, 0.1);
  background-color: white;
}
.item>image{
  width: 95%;
  border-radius: 10%;
}
.item>view{
  display: flex;
  flex-direction: column;
  font-weight: bold;
}
.introduction{
  font-size: larger;
}
.price{
  color: red;
  font-size: large;
}