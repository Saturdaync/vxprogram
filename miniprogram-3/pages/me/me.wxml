<!--pages/me/me.wxml-->
<view class="container1">
  <image src="{{avatarUrl}}" class="avatar"
  mode="aspectFill" bindtap="chooseAvatar"></image>
  <input class="nick-input"
    placeholder="请输入昵称"
    value="{{nickname}}"
    bindinput="onNickInput"
  />
  <view class="container7">
  <image src="/imgs/setting.png" class="picture3" bindtap="click">
  </image>
  <view wx:if="{{showModal}}" class="container8">
  <view class="top">登录</view>
  <view class="bottom">退出登录</view>
  </view>
  </view>
</view>
<view class="container6">
<view class="container2">
<image src="/imgs/order.png" class="picture1"></image>
<text selectable>我的订单</text>
<image src="/imgs/arrow.png" class="picture2"></image>
</view>
<view class="container3">
<image src="/imgs/collect.png" class="picture1"></image>
<text selectable>我的收藏</text>
<image src="/imgs/arrow.png" class="picture2"></image>
</view>
<view class="container4">
<image src="/imgs/release.png" class="picture1"></image>
<text selectable>我的发布</text>
<image src="/imgs/arrow.png" class="picture2"></image>
</view>
<view class="container5">
<image src="/imgs/message.png" class="picture1"></image>
<text selectable>我的消息</text>
<image src="/imgs/arrow.png" class="picture2"></image>
</view>
</view>
