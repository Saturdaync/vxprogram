/* pages/me/me.wxss */
.picture1{
  width: 30px;
  height: 40px;
}
.picture2{
  margin-left: auto;
  width: 20px;
  height: 20px;
}
text{
  margin-left: 10px;
}
.container1{
  height: 200px;
  background-color: #b8d3f0f3;
  border-bottom-left-radius: 20px;
  border-bottom-right-radius: 20px;
  display: flex;
}
.avatar{
  height: 70px;
  width: 70px;
  border-radius: 50%;
  margin-left: 30px;
  margin-top: 65px;
}
.nick-input{
  margin-left: 20px;
  margin-top: 90px;
  border-bottom: 3px solid rgb(39, 38, 38);
  width: 100px;
}
.container7{
  display: flex;
  flex-direction: column;
}
.picture3{
  margin-top: 20px;
  margin-left: 120px;
  height: 25px;
  width: 25px;
}
.container8{
  width: 90px;
  background: white;
  margin-left: auto;
  margin-top: 10px;
  border-radius: 5px;
}
.container8 view{
  border: 1px solid black;
  height: 20px;
  padding: 10px;
}
.top{
  border-top-left-radius: 5px;
  border-top-right-radius: 5px;
}
.bottom{
  border-bottom-left-radius: 5px;
  border-bottom-right-radius: 5px;
}
.container6{
  height: 400px;
  width: 350px;
  position: absolute;
  top: 170px;       
  left: 50%;        
  transform: translateX(-50%);
  z-index: 999;    
  background-color: aliceblue;
  border-radius: 10px;
  display: flex;
  flex-direction: column;
}
.container2,.container3,.container4,.container5{
  height: 70px;
  width: 310px;
  padding: 0 20px;
  border-radius: 10px;
  margin-bottom: 20px;
  background-color: white;
  display: flex;
  align-items: center;
}
